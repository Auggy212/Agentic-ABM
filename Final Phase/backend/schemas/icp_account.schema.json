{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abm-engine/schemas/icp_account.schema.json",
  "title": "ICPAccount",
  "description": "A single scored account produced by ICP Scout.",
  "type": "object",
  "required": [
    "domain", "company_name", "website", "industry",
    "headcount", "estimated_arr", "funding_stage",
    "last_funding_round", "hq_location", "technologies_used",
    "recent_signals", "icp_score", "score_breakdown", "tier",
    "source", "enriched_at"
  ],
  "additionalProperties": false,
  "properties": {
    "domain": {
      "type": "string",
      "description": "Unique key — apex domain, e.g. acme.com"
    },
    "company_name": { "type": "string", "minLength": 1 },
    "website": { "type": "string", "format": "uri" },
    "linkedin_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "industry": { "type": "string" },
    "headcount": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "string", "const": "not_found" }
      ]
    },
    "estimated_arr": {
      "oneOf": [
        { "type": "string", "not": { "const": "not_found" } },
        { "type": "string", "const": "not_found" }
      ],
      "description": "ARR as a human-readable range string or 'not_found'"
    },
    "funding_stage": { "type": "string" },
    "last_funding_round": {
      "type": "object",
      "required": ["round", "amount_usd", "date"],
      "additionalProperties": false,
      "properties": {
        "round": { "type": "string" },
        "amount_usd": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "const": "not_found" }
          ]
        },
        "date": {
          "oneOf": [
            { "type": "string", "format": "date" },
            { "type": "string", "const": "not_found" }
          ]
        }
      }
    },
    "hq_location": { "type": "string" },
    "technologies_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recent_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "description", "date", "source_url"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string" },
          "description": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "source_url": {
            "oneOf": [
              { "type": "string", "format": "uri" },
              { "type": "string", "const": "not_found" }
            ]
          }
        }
      }
    },
    "icp_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Composite ICP score 0–100"
    },
    "score_breakdown": {
      "type": "object",
      "required": ["industry", "company_size", "geography", "tech_stack", "funding_stage", "buying_triggers"],
      "additionalProperties": false,
      "properties": {
        "industry":         { "type": "integer", "minimum": 0 },
        "company_size":     { "type": "integer", "minimum": 0 },
        "geography":        { "type": "integer", "minimum": 0 },
        "tech_stack":       { "type": "integer", "minimum": 0 },
        "funding_stage":    { "type": "integer", "minimum": 0 },
        "buying_triggers":  { "type": "integer", "minimum": 0 }
      }
    },
    "tier": {
      "type": "string",
      "enum": ["TIER_1", "TIER_2", "TIER_3"],
      "description": "TIER_1: 80–100, TIER_2: 60–79, TIER_3: 0–59"
    },
    "source": {
      "type": "string",
      "enum": ["APOLLO", "HARMONIC", "CRUNCHBASE", "BUILTWITH", "CLIENT_UPLOAD"]
    },
    "enriched_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of enrichment"
    }
  }
}
