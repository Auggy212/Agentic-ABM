{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abm-engine/schemas/message.schema.json",
  "title": "Message",
  "description": "A single Storyteller-generated outreach message draft. Tier-aware traceability: Tier 1 hard-blocks untraced personalization layers; Tier 2/3 soft-flags. Validation runs at generation time AND review time (belt-and-suspenders for hallucination prevention).",
  "type": "object",
  "required": [
    "message_id",
    "client_id",
    "account_domain",
    "contact_id",
    "tier",
    "channel",
    "sequence_position",
    "subject",
    "body",
    "personalization_layers",
    "generation_metadata",
    "validation_state",
    "review_state",
    "operator_edit_history",
    "last_updated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "message_id": {"type": "string", "format": "uuid"},
    "client_id": {"type": "string", "format": "uuid"},
    "account_domain": {"type": "string", "minLength": 1, "description": "FK to icp_account.domain"},
    "contact_id": {
      "anyOf": [
        {"type": "string", "format": "uuid"},
        {"type": "null"}
      ],
      "description": "FK to buyer_profile.contact_id. Null only for REDDIT_STRATEGY_NOTE (account-level brief, not contact-level)."
    },
    "tier": {
      "type": "string",
      "enum": ["TIER_1", "TIER_2", "TIER_3"],
      "description": "Copied from icp_account.tier. Drives engine routing (T1=Claude, T2/T3=GPT-4o-mini) AND validation strictness."
    },
    "channel": {
      "type": "string",
      "enum": [
        "LINKEDIN_CONNECTION",
        "LINKEDIN_DM",
        "EMAIL",
        "WHATSAPP",
        "REDDIT_STRATEGY_NOTE"
      ]
    },
    "sequence_position": {
      "type": "integer",
      "minimum": 0,
      "description": "0=first touch, 1=follow-up #1, etc."
    },
    "subject": {
      "anyOf": [
        {"type": "string", "minLength": 1},
        {"type": "null"}
      ],
      "description": "Required for EMAIL channel; null for all others."
    },
    "body": {"type": "string", "minLength": 1},
    "personalization_layers": {
      "type": "object",
      "required": ["account_hook", "buyer_hook", "pain", "value"],
      "additionalProperties": false,
      "properties": {
        "account_hook": {"$ref": "#/$defs/PersonalizationLayer"},
        "buyer_hook": {"$ref": "#/$defs/PersonalizationLayer"},
        "pain": {"$ref": "#/$defs/PersonalizationLayer"},
        "value": {"$ref": "#/$defs/PersonalizationLayer"}
      }
    },
    "generation_metadata": {
      "type": "object",
      "required": [
        "engine",
        "model_version",
        "prompt_template_id",
        "generated_at",
        "token_usage",
        "generation_attempt",
        "diversity_signature"
      ],
      "additionalProperties": false,
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["ANTHROPIC_CLAUDE", "OPENAI_GPT_4O_MINI"]
        },
        "model_version": {"type": "string", "minLength": 1},
        "prompt_template_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "token_usage": {
          "type": "object",
          "required": ["input_tokens", "output_tokens", "estimated_cost_usd"],
          "additionalProperties": false,
          "properties": {
            "input_tokens": {"type": "integer", "minimum": 0},
            "output_tokens": {"type": "integer", "minimum": 0},
            "estimated_cost_usd": {"type": "number", "minimum": 0}
          }
        },
        "generation_attempt": {
          "type": "integer",
          "minimum": 1,
          "description": "1 for first try, 2/3 for regeneration retries on HARD_FAIL"
        },
        "diversity_signature": {
          "type": "string",
          "minLength": 1,
          "description": "Normalized hash of personalization layers. Used by diversity validator to detect collisions."
        }
      }
    },
    "validation_state": {
      "type": "object",
      "required": [
        "traceability",
        "traceability_failures",
        "diversity",
        "diversity_collision_with",
        "freshness",
        "freshness_failures"
      ],
      "additionalProperties": false,
      "properties": {
        "traceability": {
          "type": "string",
          "enum": ["PASSED", "SOFT_FAIL", "HARD_FAIL"]
        },
        "traceability_failures": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["layer", "reason"],
            "additionalProperties": false,
            "properties": {
              "layer": {
                "type": "string",
                "enum": ["account_hook", "buyer_hook", "pain", "value"]
              },
              "reason": {"type": "string", "minLength": 1}
            }
          }
        },
        "diversity": {
          "type": "string",
          "enum": ["PASSED", "FAILED", "SKIPPED"]
        },
        "diversity_collision_with": {
          "type": "array",
          "items": {"type": "string", "format": "uuid"}
        },
        "freshness": {
          "type": "string",
          "enum": ["PASSED", "FAILED"]
        },
        "freshness_failures": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["layer", "reason"],
            "additionalProperties": false,
            "properties": {
              "layer": {
                "type": "string",
                "enum": ["account_hook", "buyer_hook", "pain", "value"]
              },
              "reason": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "review_state": {
      "type": "string",
      "enum": [
        "PENDING",
        "DRAFT_VALIDATED",
        "EDITED_BY_OPERATOR",
        "APPROVED",
        "REJECTED",
        "REQUIRES_REGENERATION"
      ]
    },
    "operator_edit_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["edited_at", "edited_by", "before", "after", "reason"],
        "additionalProperties": false,
        "properties": {
          "edited_at": {"type": "string", "format": "date-time"},
          "edited_by": {"type": "string", "minLength": 1},
          "before": {"type": "string"},
          "after": {"type": "string"},
          "reason": {"type": "string"}
        }
      }
    },
    "last_updated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "PersonalizationLayer": {
      "type": "object",
      "required": ["text", "source_claim_id", "source_type", "untraced"],
      "additionalProperties": false,
      "properties": {
        "text": {"type": "string"},
        "source_claim_id": {
          "anyOf": [
            {"type": "string", "format": "uuid"},
            {"type": "null"}
          ]
        },
        "source_type": {
          "type": "string",
          "enum": [
            "INTEL_REPORT_PRIORITY",
            "INTEL_REPORT_COMPETITOR",
            "INTEL_REPORT_PAIN",
            "BUYER_PAIN_POINT",
            "JOB_CHANGE_SIGNAL",
            "SIGNAL_TIMELINE",
            "MASTER_CONTEXT_VALUE_PROP",
            "MASTER_CONTEXT_WIN_THEME",
            "RECENT_ACTIVITY",
            "UNTRACED"
          ]
        },
        "untraced": {"type": "boolean"}
      }
    }
  }
}
