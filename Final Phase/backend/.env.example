# HTTP port for the backend API server
PORT=3001

# Primary database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/abm_engine

# Redis connection for caching, queues, or rate limiting
REDIS_URL=redis://localhost:6379

# Apollo.io API key — ICP Scout source adapter (free tier: 50 exports/month)
# Get it at: https://developer.apollo.io/
APOLLO_API_KEY=hTZrpWOzBjTHy7cWVy4wLg

# Harmonic.ai API key — funded startup discovery with hiring momentum signals
# Get it at: https://harmonic.ai/
HARMONIC_API_KEY=

# Crunchbase API key — company funding and location data (Basic tier: 200 results/month)
# Get it at: https://data.crunchbase.com/docs/using-the-api
CRUNCHBASE_API_KEY=

# BuiltWith API key — technology stack detection by domain
# Get it at: https://api.builtwith.com/
BUILTWITH_API_KEY=

# Clay account key for Clay data workflows or enrichment
CLAY_API_KEY=

# Hunter account key for email discovery and verification
HUNTER_API_KEY=

# NeverBounce account key for email validation
NEVERBOUNCE_API_KEY=

# ZeroBounce account key for ambiguous email validation fallback
ZEROBOUNCE_API_KEY=

# HubSpot private app or API key for CRM sync
HUBSPOT_API_KEY=

# Twilio Account SID for SMS or calling integrations
TWILIO_ACCOUNT_SID=

# Twilio auth token paired with the Account SID
TWILIO_AUTH_TOKEN=

# Anthropic API key for LLM-powered backend features
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API key for Tier 2/3 Storyteller generation
OPENAI_API_KEY=your-openai-api-key-here

# Per-run Storyteller budget caps
ANTHROPIC_RUN_BUDGET_USD=50
OPENAI_RUN_BUDGET_USD=20

# Temporary admin token for prompt template write endpoints
TEMPLATE_ADMIN_TOKEN=

# Instantly API key for outbound email automation
INSTANTLY_API_KEY=

# --- Phase 5 webhook signing secrets (set per-provider in production) ---
# Instantly: HMAC SHA-256 of the raw request body, hex-encoded, in X-Instantly-Signature
INSTANTLY_WEBHOOK_SECRET=
# PhantomBuster: shared header secret in X-PB-Signature (free tier has no payload signing)
PHANTOMBUSTER_WEBHOOK_SECRET=
# Twilio uses TWILIO_AUTH_TOKEN above for X-Twilio-Signature validation

# Phase 5 reply classifier — daily USD budget cap on Claude calls; on exhaust the
# regex fallback runs and the contact is paused regardless (master prompt §5).
REPLY_CLASSIFIER_DAILY_BUDGET_USD=5.0
REPLY_CLASSIFIER_USE_MOCK=1
