# Core runtime
# HTTP port for the backend API server (Phase 0 - platform bootstrap)
PORT=3001

# Primary database connection string (Phase 0 - platform bootstrap)
DATABASE_URL=postgresql://user:password@localhost:5432/abm_engine

# Redis connection for caching, queues, or rate limiting (Phase 0 - platform bootstrap)
REDIS_URL=redis://localhost:6379

# n8n basic auth user for self-hosted workflow UI (Phase 0 - orchestration)
N8N_BASIC_AUTH_USER=admin

# n8n basic auth password for self-hosted workflow UI (Phase 0 - orchestration)
N8N_BASIC_AUTH_PASSWORD=change-me

# Intake Agent (Phase 1)
# Tally webhook secret (optional if Tally webhook signing is enabled)
TALLY_WEBHOOK_SECRET=

# Tally form identifier used by intake workflow
TALLY_FORM_ID=

# ICP Scout + Buyer Intel (Phase 2)
# Apollo enrichment/prospecting API key
APOLLO_API_KEY=

# Clay API key for enrichment workflows
CLAY_API_KEY=

# Harmonic API key (if enabled for your account plan)
HARMONIC_API_KEY=

# Crunchbase manual-only mode (no API key in free workflow)
CRUNCHBASE_MANUAL_MODE=true

# Hunter API key for email discovery
HUNTER_API_KEY=

# PhantomBuster API key
PHANTOMBUSTER_API_KEY=

# LinkedIn li_at cookie token for PhantomBuster sessions (treat as secret)
PHANTOMBUSTER_LINKEDIN_LI_AT=

# Evaboot API key / token (if available in your plan)
EVABOOT_API_KEY=

# Lusha API key
LUSHA_API_KEY=

# Signal & Intelligence (Phase 3)
# Perplexity API key for intelligence synthesis
PERPLEXITY_API_KEY=

# SparkToro manual-only mode (no API key in free workflow)
SPARKTORO_MANUAL_MODE=true

# Reddit API app credentials
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=abm-engine/1.0 (by /u/your_reddit_username)

# Verifier (Phase 4)
# NeverBounce API key for email validation
NEVERBOUNCE_API_KEY=

# ZeroBounce API key for secondary verification
ZEROBOUNCE_API_KEY=

# Storyteller (Phase 5)
# Anthropic API key for Claude message generation
ANTHROPIC_API_KEY=

# Campaign (Phase 6)
# HubSpot private app access token for CRM sync
HUBSPOT_ACCESS_TOKEN=

# Instantly API key (start trial in Week 9)
INSTANTLY_API_KEY=

# Twilio core credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio WhatsApp sandbox sender (for example: whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM_NUMBER=

# Cal.com API key for scheduling links and booking sync
CALCOM_API_KEY=
