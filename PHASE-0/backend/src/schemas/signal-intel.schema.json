{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SignalIntelContract",
  "type": "object",
  "required": ["input", "output"],
  "properties": {
    "input": {
      "type": "object",
      "required": ["companyDomain"],
      "properties": {
        "companyDomain": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "required": ["buyingStage", "signals", "intelReport"],
      "properties": {
        "buyingStage": { "type": "string" },
        "signals": { "type": "array", "items": { "type": "string" } },
        "intelReport": { "type": "string" }
      }
    }
  }
}
