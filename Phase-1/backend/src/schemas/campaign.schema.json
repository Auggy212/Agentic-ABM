{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CampaignContract",
  "type": "object",
  "required": ["input", "output"],
  "properties": {
    "input": {
      "type": "object",
      "required": ["contactIds"],
      "properties": {
        "contactIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "output": {
      "type": "object",
      "required": ["campaignId", "status"],
      "properties": {
        "campaignId": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  }
}
