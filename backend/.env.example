# HTTP port for the backend API server
PORT=3001

# Primary database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/abm_engine

# Redis connection for caching, queues, or rate limiting
REDIS_URL=redis://localhost:6379

# Apollo.io API key — ICP Scout source adapter (free tier: 50 exports/month)
# Get it at: https://developer.apollo.io/
APOLLO_API_KEY=

# Harmonic.ai API key — funded startup discovery with hiring momentum signals
# Get it at: https://harmonic.ai/
HARMONIC_API_KEY=

# Crunchbase API key — company funding and location data (Basic tier: 200 results/month)
# Get it at: https://data.crunchbase.com/docs/using-the-api
CRUNCHBASE_API_KEY=

# BuiltWith API key — technology stack detection by domain
# Get it at: https://api.builtwith.com/
BUILTWITH_API_KEY=

# Clay account key for Clay data workflows or enrichment
CLAY_API_KEY=

# Hunter account key for email discovery and verification
HUNTER_API_KEY=

# NeverBounce account key for email validation
NEVERBOUNCE_API_KEY=

# HubSpot private app or API key for CRM sync
HUBSPOT_API_KEY=

# Twilio Account SID for SMS or calling integrations
TWILIO_ACCOUNT_SID=

# Twilio auth token paired with the Account SID
TWILIO_AUTH_TOKEN=

# Anthropic API key for LLM-powered backend features
ANTHROPIC_API_KEY=

# Instantly API key for outbound email automation
INSTANTLY_API_KEY=
