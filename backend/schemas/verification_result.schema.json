{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abm-engine/schemas/verification_result.schema.json",
  "title": "VerificationResult",
  "description": "Verifier Agent output for one BuyerProfile.",
  "type": "object",
  "required": [
    "contact_id",
    "account_domain",
    "email_verification",
    "linkedin_check",
    "website_check",
    "title_reconciliation",
    "job_change_verification",
    "overall_data_quality_score",
    "issues",
    "verified_at"
  ],
  "additionalProperties": false,
  "properties": {
    "contact_id": {
      "type": "string",
      "format": "uuid",
      "description": "FK to buyer_profile.contact_id"
    },
    "account_domain": {
      "type": "string",
      "description": "FK to buyer_profile.account_domain"
    },
    "email_verification": {
      "$ref": "#/$defs/EmailVerification"
    },
    "linkedin_check": {
      "$ref": "#/$defs/LinkedinCheck"
    },
    "website_check": {
      "$ref": "#/$defs/WebsiteCheck"
    },
    "title_reconciliation": {
      "$ref": "#/$defs/TitleReconciliation"
    },
    "job_change_verification": {
      "$ref": "#/$defs/JobChangeVerification"
    },
    "overall_data_quality_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/VerificationIssue"
      }
    },
    "verified_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "email_verification": {
            "properties": {
              "secondary_engine": { "const": "ZEROBOUNCE" }
            },
            "required": ["secondary_engine"]
          }
        },
        "required": ["email_verification"]
      },
      "then": {
        "properties": {
          "email_verification": {
            "properties": {
              "secondary_result": { "$ref": "#/$defs/EmailEngineResult" }
            },
            "required": ["secondary_result"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "email_verification": {
            "properties": {
              "secondary_engine": { "type": "null" }
            },
            "required": ["secondary_engine"]
          }
        },
        "required": ["email_verification"]
      },
      "then": {
        "properties": {
          "email_verification": {
            "properties": {
              "secondary_result": { "type": "null" }
            },
            "required": ["secondary_result"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "email_verification": {
            "properties": {
              "relookup_attempted": { "const": true }
            },
            "required": ["relookup_attempted"]
          }
        },
        "required": ["email_verification"]
      },
      "then": {
        "properties": {
          "email_verification": {
            "anyOf": [
              {
                "properties": {
                  "relookup_email": { "type": "string", "minLength": 1 }
                },
                "required": ["relookup_email"]
              },
              {
                "properties": {
                  "relookup_blocked_reason": {
                    "$ref": "#/$defs/RelookupBlockedReason"
                  }
                },
                "required": ["relookup_blocked_reason"]
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "linkedin_check": {
            "properties": {
              "http_status": { "const": 999 }
            },
            "required": ["http_status"]
          }
        },
        "required": ["linkedin_check"]
      },
      "then": {
        "properties": {
          "linkedin_check": {
            "properties": {
              "check_authoritative": { "const": false }
            },
            "required": ["check_authoritative"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "linkedin_check": {
            "properties": {
              "http_status": {
                "type": "integer",
                "not": { "const": 999 }
              }
            },
            "required": ["http_status"]
          }
        },
        "required": ["linkedin_check"]
      },
      "then": {
        "properties": {
          "linkedin_check": {
            "properties": {
              "check_authoritative": { "const": true }
            },
            "required": ["check_authoritative"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "title_reconciliation": {
            "properties": {
              "resolution_method": { "const": "LINKEDIN_PRIMARY" }
            },
            "required": ["resolution_method"]
          }
        },
        "required": ["title_reconciliation"]
      },
      "then": {
        "properties": {
          "title_reconciliation": {
            "properties": {
              "linkedin_title": { "type": "string", "minLength": 1 }
            },
            "required": ["linkedin_title"]
          }
        }
      }
    }
  ],
  "$defs": {
    "EmailFinalStatus": {
      "type": "string",
      "enum": ["VALID", "INVALID", "CATCH_ALL", "RISKY", "NOT_FOUND"]
    },
    "EngineName": {
      "type": "string",
      "enum": ["NEVERBOUNCE", "ZEROBOUNCE"]
    },
    "RelookupBlockedReason": {
      "type": "string",
      "enum": ["QUOTA_EXHAUSTED", "NO_MATCH"]
    },
    "EmailEngineResult": {
      "type": "object",
      "required": ["status", "confidence", "sub_status", "checked_at"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "$ref": "#/$defs/EmailFinalStatus"
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "sub_status": {
          "type": "string",
          "description": "Provider-specific detail, e.g. mailbox_full"
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "EmailVerification": {
      "type": "object",
      "required": [
        "email",
        "status",
        "primary_engine",
        "secondary_engine",
        "primary_result",
        "secondary_result",
        "relookup_attempted",
        "relookup_source",
        "relookup_email",
        "relookup_blocked_reason",
        "final_status"
      ],
      "additionalProperties": false,
      "properties": {
        "email": { "type": "string" },
        "status": { "$ref": "#/$defs/EmailFinalStatus" },
        "primary_engine": { "$ref": "#/$defs/EngineName" },
        "secondary_engine": {
          "oneOf": [
            { "type": "string", "const": "ZEROBOUNCE" },
            { "type": "null" }
          ]
        },
        "primary_result": { "$ref": "#/$defs/EmailEngineResult" },
        "secondary_result": {
          "oneOf": [
            { "$ref": "#/$defs/EmailEngineResult" },
            { "type": "null" }
          ]
        },
        "relookup_attempted": { "type": "boolean" },
        "relookup_source": {
          "oneOf": [
            { "type": "string", "const": "HUNTER" },
            { "type": "null" }
          ]
        },
        "relookup_email": {
          "type": ["string", "null"]
        },
        "relookup_blocked_reason": {
          "oneOf": [
            { "$ref": "#/$defs/RelookupBlockedReason" },
            { "type": "null" }
          ]
        },
        "final_status": { "$ref": "#/$defs/EmailFinalStatus" }
      }
    },
    "LinkedinCheck": {
      "type": "object",
      "required": ["url", "reachable", "http_status", "check_authoritative", "checked_at"],
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": ["string", "null"]
        },
        "reachable": { "type": "boolean" },
        "http_status": {
          "type": ["integer", "null"],
          "minimum": 100,
          "maximum": 999
        },
        "check_authoritative": {
          "type": "boolean",
          "description": "false when http_status=999; true for non-999 HTTP results"
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "WebsiteCheck": {
      "type": "object",
      "required": ["domain", "reachable", "http_status", "checked_at"],
      "additionalProperties": false,
      "properties": {
        "domain": { "type": "string" },
        "reachable": { "type": "boolean" },
        "http_status": {
          "type": ["integer", "null"],
          "minimum": 100,
          "maximum": 599
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "TitleReconciliation": {
      "type": "object",
      "required": [
        "apollo_title",
        "linkedin_title",
        "resolved_title",
        "resolution_method",
        "mismatch_resolved"
      ],
      "additionalProperties": false,
      "properties": {
        "apollo_title": { "type": "string" },
        "linkedin_title": { "type": ["string", "null"] },
        "resolved_title": { "type": "string" },
        "resolution_method": {
          "type": "string",
          "enum": [
            "LINKEDIN_PRIMARY",
            "APOLLO_FALLBACK",
            "NO_RECONCILIATION_POSSIBLE"
          ]
        },
        "mismatch_resolved": { "type": "boolean" }
      }
    },
    "JobChangeVerification": {
      "type": "object",
      "required": ["apollo_claimed", "linkedin_confirmed", "verified", "confidence"],
      "additionalProperties": false,
      "properties": {
        "apollo_claimed": { "type": "boolean" },
        "linkedin_confirmed": { "type": ["boolean", "null"] },
        "verified": { "type": "boolean" },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "VerificationIssue": {
      "type": "object",
      "required": ["severity", "code", "message"],
      "additionalProperties": false,
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["ERROR", "WARNING", "INFO"]
        },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
