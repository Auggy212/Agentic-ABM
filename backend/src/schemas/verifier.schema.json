{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VerifierContract",
  "type": "object",
  "required": ["input", "output"],
  "properties": {
    "input": {
      "type": "object",
      "required": ["scope"],
      "properties": {
        "scope": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "required": ["verificationId", "status"],
      "properties": {
        "verificationId": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  }
}
